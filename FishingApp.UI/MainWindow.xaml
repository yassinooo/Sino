<Window x:Class="FishingApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FishingApp" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Buyers" Click="MenuItem_Buyers_Click" />
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Bids" FontSize="18" Margin="8"/>
            <DataGrid Grid.Row="1" ItemsSource="{Binding Bids}" AutoGenerateColumns="True" Margin="8"/>
        </Grid>
    </DockPanel>
</Window>
