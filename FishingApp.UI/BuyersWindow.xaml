<Window x:Class="FishingApp.UI.BuyersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buyers" Height="450" Width="800">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <Button Name="BtnAdd" Content="Add Sample" Width="100" Margin="0,0,8,0" Click="BtnAdd_Click" />
            <Button Name="BtnDelete" Content="Delete Selected" Width="120" Click="BtnDelete_Click" />
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="DgBuyers" ItemsSource="{Binding Buyers}" AutoGenerateColumns="True" />

        <TextBlock Grid.Row="2" Text="Tip: Use Add Sample to create a new buyer quickly." Margin="0,8,0,0" />
    </Grid>
</Window>
